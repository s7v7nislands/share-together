/* pages/room/room.wxss */
.page {
  padding: 24rpx 24rpx 80rpx;
}

/* Room head */
.room-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.eyebrow {
  font-size: 20rpx;
  font-weight: 800;
  color: #8c4f2b;
  letter-spacing: 2rpx;
  margin-bottom: 4rpx;
}

.room-slug {
  font-size: 32rpx;
  font-weight: 700;
  color: #24211c;
}

.share-btn {
  font-size: 26rpx;
  height: 64rpx;
  padding: 0 24rpx;
  border-radius: 8rpx;
}

/* Submit form */
.submit-form {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.form-input {
  border: 1rpx solid #d9d2c5;
  border-radius: 8rpx;
  padding: 0 20rpx;
  height: 80rpx;
  background: #fff;
  font-size: 28rpx;
  color: #24211c;
}

.submit-btn {
  height: 80rpx;
  font-size: 30rpx;
  border-radius: 8rpx;
}

/* Tabs */
.tabs {
  display: flex;
  gap: 8rpx;
  background: #eee7da;
  border: 1rpx solid #d9d2c5;
  border-radius: 8rpx;
  padding: 6rpx;
  width: fit-content;
  margin-bottom: 20rpx;
}

.tab {
  background: transparent;
  color: #615b50;
  font-size: 26rpx;
  padding: 0 24rpx;
  height: 60rpx;
  border-radius: 6rpx;
  border: 1rpx solid transparent;
}

.tab.active {
  background: #fff;
  color: #24211c;
  border-color: #d9d2c5;
}

/* Tag filters */
.tag-filters {
  display: flex;
  white-space: nowrap;
  margin-bottom: 20rpx;
  gap: 10rpx;
}

.tag-filters.hidden {
  display: none;
}

.tag-filter {
  display: inline-block;
  background: #f6f1e8;
  border: 1rpx solid #ded5c6;
  border-radius: 30rpx;
  color: #5a4f43;
  font-size: 24rpx;
  height: 56rpx;
  padding: 0 20rpx;
  margin-right: 8rpx;
  white-space: nowrap;
}

.tag-filter.active {
  background: #165a4c;
  border-color: #165a4c;
  color: #fff;
}

/* Link cards */
.links {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.link-card {
  background: #fff;
  border: 1rpx solid #ddd5c8;
  border-radius: 12rpx;
  overflow: hidden;
}

.thumb {
  width: 100%;
  height: 280rpx;
  display: block;
}

.link-content {
  padding: 20rpx 20rpx 16rpx;
}

.meta {
  font-size: 22rpx;
  color: #726b60;
  margin-bottom: 8rpx;
  display: block;
}

.link-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #24211c;
  line-height: 1.4;
  display: block;
  margin-bottom: 8rpx;
}

.recommendation {
  border-left: 4rpx solid #c9783d;
  color: #4d473e;
  font-size: 26rpx;
  line-height: 1.5;
  padding-left: 14rpx;
  margin: 10rpx 0;
  display: block;
}

.link-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin: 8rpx 0;
}

.tag {
  background: #f6f1e8;
  border-radius: 30rpx;
  color: #5a4f43;
  font-size: 22rpx;
  padding: 4rpx 14rpx;
}

.description {
  color: #4d473e;
  font-size: 26rpx;
  line-height: 1.5;
  margin: 8rpx 0;
  display: block;
}

/* Actions */
.actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.vote-btn {
  background: #eef6f1;
  border: 1rpx solid #c4dccf;
  border-radius: 8rpx;
  color: #165a4c;
  font-weight: 800;
  font-size: 24rpx;
  height: 60rpx;
  padding: 0 20rpx;
}

.vote-btn.active {
  background: #165a4c;
  color: #fff;
}

.comment-toggle {
  background: #f6f3ee;
  border: 1rpx solid #d9d2c5;
  border-radius: 8rpx;
  color: #4d473e;
  font-size: 24rpx;
  height: 60rpx;
  padding: 0 18rpx;
}

.comment-toggle.active {
  background: #e9e0d0;
  border-color: #bfb8ae;
}

.edit-btn {
  background: transparent;
  border: 1rpx solid #d9d2c5;
  border-radius: 8rpx;
  color: #615b50;
  font-size: 22rpx;
  height: 60rpx;
  padding: 0 14rpx;
}

.delete-btn {
  background: transparent;
  border: 1rpx solid transparent;
  border-radius: 8rpx;
  color: #9b3f2f;
  font-size: 24rpx;
  height: 60rpx;
  padding: 0 12rpx;
}

.empty-text {
  color: #615b50;
  font-size: 28rpx;
  text-align: center;
  padding: 60rpx 0;
  display: block;
}

/* ── Comment section ───────────────────────────────────────────────────── */
.comment-section {
  border-top: 1rpx solid #e8e2d9;
  margin-top: 16rpx;
  padding-top: 16rpx;
}

.comment-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-bottom: 16rpx;
}

.comment-body {
  background: #f9f7f3;
  border: 1rpx solid #e8e2d9;
  border-radius: 8rpx;
  padding: 14rpx 16rpx;
}

.reply-body {
  margin-left: 24rpx;
  border-left: 3rpx solid #d9d2c5;
  border-radius: 0 8rpx 8rpx 0;
}

.comment-replies {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-top: 10rpx;
}

.comment-meta {
  font-size: 20rpx;
  color: #8c8478;
  display: block;
  margin-bottom: 6rpx;
}

.comment-content {
  font-size: 26rpx;
  color: #2e2a24;
  line-height: 1.55;
  display: block;
}

.comment-attachments {
  margin-top: 10rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.comment-image {
  width: 100%;
  border-radius: 8rpx;
}

.comment-md-block {
  background: #fff;
  border: 1rpx solid #d9d2c5;
  border-radius: 8rpx;
  overflow: hidden;
}

.comment-md-name {
  font-size: 22rpx;
  color: #615b50;
  display: block;
  padding: 8rpx 14rpx;
}

.comment-md-scroll {
  height: 200rpx;
  border-top: 1rpx solid #e8e2d9;
}

.comment-md-content {
  font-family: "Menlo", "Courier New", monospace;
  font-size: 22rpx;
  color: #2e2a24;
  line-height: 1.55;
  padding: 12rpx 14rpx;
  display: block;
  white-space: pre-wrap;
}

.reply-btn {
  background: transparent;
  border: none;
  color: #8c4f2b;
  font-size: 22rpx;
  margin-top: 6rpx;
  padding: 0;
  height: 40rpx;
}

/* Comment form */
.comment-form {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.comment-textarea {
  border: 1rpx solid #d9d2c5;
  border-radius: 8rpx;
  padding: 14rpx 16rpx;
  background: #fff;
  font-size: 26rpx;
  min-height: 100rpx;
  line-height: 1.5;
  width: 100%;
}

.comment-toolbar {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.attach-btn {
  background: #f6f1e8;
  border: 1rpx solid #ded5c6;
  border-radius: 8rpx;
  color: #5a4f43;
  font-size: 22rpx;
  height: 60rpx;
  padding: 0 18rpx;
}

.comment-submit {
  font-size: 26rpx;
  height: 60rpx;
  padding: 0 28rpx;
  border-radius: 8rpx;
}

/* ── Edit modal ─────────────────────────────────────────────────────────── */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 32rpx;
}

.modal-overlay.hidden {
  display: none;
}

.modal {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx 36rpx 32rpx;
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  box-shadow: 0 8rpx 60rpx rgba(0,0,0,0.18);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #24211c;
}

.modal-field {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.modal-label {
  font-size: 24rpx;
  color: #4d473e;
  font-weight: 600;
}

.modal-input {
  border: 1rpx solid #d9d2c5;
  border-radius: 8rpx;
  padding: 0 18rpx;
  height: 72rpx;
  background: #fff;
  font-size: 26rpx;
}

.modal-textarea {
  border: 1rpx solid #d9d2c5;
  border-radius: 8rpx;
  padding: 14rpx 18rpx;
  background: #fff;
  font-size: 26rpx;
  min-height: 100rpx;
  line-height: 1.5;
}

.modal-actions {
  display: flex;
  gap: 12rpx;
  justify-content: flex-end;
}

.modal-save-btn {
  height: 72rpx;
  font-size: 28rpx;
  padding: 0 36rpx;
  border-radius: 8rpx;
}

.modal-cancel-btn {
  height: 72rpx;
  font-size: 28rpx;
  padding: 0 28rpx;
  border-radius: 8rpx;
}
