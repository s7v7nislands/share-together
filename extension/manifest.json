{
  "manifest_version": 3,
  "name": "Share Together",
  "version": "0.1.0",
  "description": "Share articles to Share Together rooms with AI-generated summaries and tags.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Share to Room"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
